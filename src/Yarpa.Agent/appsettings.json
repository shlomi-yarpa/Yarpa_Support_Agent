{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Agent": {
    "ApiBaseUrl": "https://localhost:7177",
    "ApiKey": "REPLACE_WITH_CUSTOMER_API_KEY",
    "RetryCount": 3,
    "RetryBaseDelaySeconds": 2,
    "OfflineQueuePath": ""
  },
  "Collectors": {
    "ServicesWatchlist": [
      "MSSQL*",
      "SQLAgent*",
      "SQLTELEMETRY",
      "W3SVC",
      "WAS",
      "Yarpa*"
    ],
    "SoftwareFilters": [
      "yarpa",
      "microsoft .net",
      ".net desktop runtime",
      ".net runtime",
      "sql server",
      "sql native client",
      "sqlncli",
      "microsoft odbc driver"
    ],
    "EventLogWindowDays": 7,
    "EventLogMaxEvents": 200,
    "EventLogSources": [ "System", "Application" ]
  },
  "YarpaDetection": {
    "RegistryKeys": [
      "HKLM\\SOFTWARE\\Yarpa\\Yarpa ERP",
      "HKLM\\SOFTWARE\\WOW6432Node\\Yarpa\\Yarpa ERP",
      "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Yarpa ERP",
      "HKLM\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Yarpa ERP"
    ],
    "ExecutablePaths": [
      "%ProgramFiles%\\Yarpa\\YarpaERP.exe",
      "%ProgramFiles(x86)%\\Yarpa\\YarpaERP.exe",
      "%ProgramFiles%\\Yarpa\\Yarpa.exe",
      "%ProgramFiles(x86)%\\Yarpa\\Yarpa.exe"
    ],
    "ConfigFilePaths": [
      "%ProgramFiles%\\Yarpa\\version.txt",
      "%ProgramFiles(x86)%\\Yarpa\\version.txt",
      "%ProgramFiles%\\Yarpa\\version.json",
      "%ProgramFiles(x86)%\\Yarpa\\version.json"
    ]
  }
}
