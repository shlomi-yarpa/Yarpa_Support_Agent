{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Agent": {
    "ApiBaseUrl": "https://localhost:7177",
    "ApiKey": "REPLACE_WITH_CUSTOMER_API_KEY",
    "RetryCount": 3,
    "RetryBaseDelaySeconds": 2,
    "OfflineQueuePath": "",
    "Service": {
      "IntervalDays": 7,
      "PreferredHourStart": 2,
      "PreferredHourEnd": 4,
      "IntervalHours": 0,
      "RunImmediatelyOnStart": true
    }
  },
  "Collectors": {
    "ServicesWatchlist": [
      "MSSQL*",
      "SQLAgent*",
      "SQLTELEMETRY",
      "W3SVC",
      "WAS",
      "Yarpa*",
      "Meusensrv*",
      "PirRepl*",
      "Dangot*"
    ],
    "SoftwareFilters": [
      "yarpa",
      "microsoft .net",
      ".net desktop runtime",
      ".net runtime",
      "sql server",
      "sql native client",
      "sqlncli",
      "microsoft odbc driver"
    ],
    "EventLogWindowDays": 7,
    "EventLogMaxEvents": 200,
    "EventLogSources": [ "System", "Application" ]
  },
  "YarpaDetection": {
    "PsoftwFolderName": "psoftw",
    "IniFileName": "piryons.ini",
    "ExecutableCandidates": [
      "piryons.exe",
      "piryon2.exe"
    ],
    "ExplicitPsoftwPaths": []
  }
}
