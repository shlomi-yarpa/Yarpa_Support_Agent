{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Comparison": {
    "DiskFreePercentChangeThreshold": 5.0
  },
  "Alerts": {
    "MinFreeDiskPercent": 10.0,
    "MinFreeDiskGb": 5.0,
    "MinSupportedYarpaBuild": 10300,
    "NoRecentContactDays": 3,
    "NoRecentContactScanIntervalMinutes": 60,
    "MonitoredServiceNames": [ "MSSQLSERVER", "SQLSERVERAGENT", "Yarpa", "Meusensrv", "PirReplMercaz2SnifService", "DangotService" ],
    "CriticalSections": [ "system", "os", "disks", "services", "sqlServer" ]
  }
}
