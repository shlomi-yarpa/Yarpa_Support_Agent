@* A single label/value row for the summary cards *@
<div class="d-flex justify-content-between align-items-baseline mb-1">
    <span class="text-muted small">@Label</span>
    @if (Bold)
    {
        <strong class="text-end" style="max-width:60%;word-break:break-word">
            @(string.IsNullOrEmpty(Value) ? "—" : Value)
        </strong>
    }
    else
    {
        <span class="text-end small" style="max-width:60%;word-break:break-word">
            @(string.IsNullOrEmpty(Value) ? "—" : Value)
        </span>
    }
</div>

@code {
    [Parameter] public string  Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool    Bold  { get; set; }
}
